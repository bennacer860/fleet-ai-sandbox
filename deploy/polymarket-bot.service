[Unit]
Description=Polymarket Bot Profile 2 (tmux)
After=network.target litestream.service
Requires=litestream.service

[Service]
Type=forking
User=ec2-user
Group=ec2-user
WorkingDirectory=/opt/polymarket-bot
EnvironmentFile=/opt/polymarket-bot/.env
Environment=USER_WS_LOG_TRADE_EVENTS=true

ExecStart=/usr/bin/tmux new-session -d -s bot-p2 -e "HOME=/home/ec2-user" \
  '/opt/polymarket-bot/.venv/bin/python main.py run --markets BTC ETH SOL XRP DOGE HYPE BNB --durations 5 15 60 240 1440 --price-threshold 0.99 --profile 2 --strategy post_expiry --claim 20 --dashboard --stocks SPX TSLA AAPL MSFT NVDA NFLX QQQ AMZN GOOGL META COIN PLTR HOOD; exec bash'
ExecStop=/usr/bin/tmux kill-session -t bot-p2

Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
